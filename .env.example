# Copy to .env and fill in. docker-compose reads this automatically.
POSTGRES_PASSWORD=devpass             # postgres superuser (migrations + ingestion)
APP_DB_PASSWORD=plantwise_app_pw      # plantwise_app pool role; backend syncs it at startup
OPENAI_API_KEY=sk-...                 # the LLM key provided with the assignment
AGENT_MODEL=gpt-5
# secret used to derive per-sandbox-role DB passwords; set a random value in prod
SANDBOX_SECRET=dev-sandbox-secret-change-in-prod
